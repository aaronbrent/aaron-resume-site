{
  "ci": {
    "collect": {
      "staticDistDir": "./build/client",
      "url": ["http://localhost/"],
      "numberOfRuns": 3,
      "settings": {
        "budgetsPath": "./budgets.json"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.95 }],
        "categories:accessibility": ["error", { "minScore": 1 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0 }],
        "resource-summary:script:size": ["error", { "maxNumericValue": 133120 }],
        "resource-summary:stylesheet:size": ["error", { "maxNumericValue": 35840 }],
        "resource-summary:font:size": ["error", { "maxNumericValue": 122880 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
